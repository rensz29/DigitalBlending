# Copy to server/.env.local and fill in the real token.
# Base URL of the historian dataset endpoint (no query string).
PI_API_BASE=HISTORIAN_API_BASE
# Optional Bearer token for the historian API (server-side only — never exposed to the browser).
# Leave as replace-with-real-token if the internal historian does not require auth.
PI_BEARER_TOKEN=HISTORIAN_BEARER_TOKEN
# Plant timezone offset from UTC, in hours. Asia/Manila = 8 (no DST).
PI_TZ_OFFSET=8

# --- OPC UA tag dashboard ---
# OPC UA server endpoint (opc.tcp://OPCUA_HOST:OPCUA_PORT).
OPCUA_HOST=OPCUA_HOST
OPCUA_PORT=OPCUA_PORT
# Credentials for the OPC UA UserName token (required to connect).
OPCUA_USERNAME=OPCUA_USERNAME
OPCUA_PASSWORD=OPCUA_PASSWORD
